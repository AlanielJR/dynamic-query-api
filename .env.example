# =============================================================
#  Dynamic Query Executor API — Variables de Entorno
#  Copiar este archivo a .env y completar los valores reales.
#  NUNCA subir el archivo .env al repositorio.
# =============================================================

# ── Servidor ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
# NODE_ENV opciones: development | production

# ── Seguridad ─────────────────────────────────────────────────
# Generar en producción con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY=test-api-key-123

# Clave de cifrado AES-256-GCM para credenciales almacenadas (OBLIGATORIA para /api)
# Generar con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: Si cambiás esta clave, las credenciales guardadas quedan ilegibles.
ENCRYPTION_KEY=cambia-esto-por-64-caracteres-hexadecimales-generados-con-el-comando

# Comandos SQL bloqueados (separados por coma, sin espacios)
BLOCKED_SQL_COMMANDS=DROP,TRUNCATE,ALTER,CREATE,GRANT,REVOKE,DELETE

# Longitud máxima de la query en caracteres
MAX_QUERY_LENGTH=10000

# ── Timeouts (milisegundos) ────────────────────────────────────
CONNECTION_TIMEOUT=10000
QUERY_TIMEOUT=30000

# ── Rate Limiting ─────────────────────────────────────────────
# Ventana de tiempo en ms (60000 = 1 minuto)
RATE_LIMIT_WINDOW_MS=60000
# Máximo de requests por ApiKey por ventana
RATE_LIMIT_MAX_REQUESTS=100

# ── Registro de conexiones (BD dedicada para las tablas de registro) ──────────────────────
# Motor: mssql | postgresql
REGISTRY_DB_TYPE=mssql
REGISTRY_DB_HOST=your-db-host
REGISTRY_DB_PORT=1433
REGISTRY_DB_NAME=DynamicQueryRegistry
REGISTRY_DB_USER=your-db-user
REGISTRY_DB_PASSWORD=your-db-password

# Nombre de tabla de conexiones (cambiar si existe con otro nombre en la BD)
TABLE_CONNECTIONS=api_connections

# ── Logging ───────────────────────────────────────────────────
# Niveles: error | warn | info | debug
LOG_LEVEL=info
